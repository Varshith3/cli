# Copy to .github/local/runtime-secrets.env for local workflow testing.
# Do not commit real secret values.

# Any valid env keys are supported (except protected keys like GITHUB_*, RUNNER_*, PATH, HOME).
# Example keys:
GHDP_TOKEN=ghp_replace_me

# Domain-specific keys are optional and workflow-dependent.
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=you@example.com
JIRA_TOKEN=replace_me
SOME_API_KEY=replace_me
