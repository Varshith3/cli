{
  "schema_version": "1.0",
  "branch_prefix": "feature",
  "intent_repo_path": ".ghdp/frbr/intent.json",
  "branch_types": [
    {
      "canonical": "TECHNICAL",
      "aliases": ["t", "tech", "technical"]
    },
    {
      "canonical": "ENHANCEMENT",
      "aliases": ["e", "enh", "enhancement"]
